# Bot Configuration
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username

# Admin Configuration (JSON format)
# Формат: ["user_id1", "user_id2"] или user_id1,user_id2
ADMIN_USER_IDS=["123456789"]

# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=botdb
POSTGRES_USER=botuser
POSTGRES_PASSWORD=securepassword

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Environment
ENV=development

# Logging
LOG_LEVEL=INFO

# ========================================
# Local Bot API Settings (Optional)
# ========================================
# Для загрузки файлов до 2GB вместо 50MB
# Получить на https://my.telegram.org

USE_LOCAL_API=false
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
LOCAL_API_HOST=telegram-bot-api
LOCAL_API_PORT=8081

# ========================================
# Local Speech-to-Text Settings (faster-whisper)
# ========================================
# Бот автоматически расшифровывает голосовые/аудио/видео сообщения
# с помощью локального сервиса transcriber (без платных API)

TRANSCRIBER_URL=http://transcriber:8001
TRANSCRIBER_TIMEOUT=300
# Размер модели: tiny, base, small, medium, large-v3 (больше = точнее, но медленнее и требует больше RAM)
WHISPER_MODEL_SIZE=small
# Тип вычислений для CPU: int8 (быстрее) или float32 (точнее)
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ru
