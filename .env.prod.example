# ========================================
# 🏭 PRODUCTION ENVIRONMENT VARIABLES
# ========================================
# ВАЖНО: Скопируйте этот файл в .env.prod и измените все значения!
# Команда: cp .env.prod.example .env.prod

# ========================================
# 🤖 BOT CONFIGURATION
# ========================================
BOT_TOKEN=your_production_bot_token_here
BOT_USERNAME=your_production_bot_username

# ========================================
# 🗄️ DATABASE CONFIGURATION  
# ========================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=botdb_prod
POSTGRES_USER=botuser_prod
# ВАЖНО: Используйте сильный пароль!
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD_123!

# ========================================
# 📦 REDIS CONFIGURATION
# ========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# ВАЖНО: В продакшене рекомендуется пароль для Redis
REDIS_PASSWORD=CHANGE_ME_TO_REDIS_PASSWORD_456!

# ========================================
# 🌍 ENVIRONMENT
# ========================================
ENV=production

# ========================================
# 📝 LOGGING
# ========================================
# В продакшене используйте WARNING или ERROR
LOG_LEVEL=WARNING

# ========================================
# 🎙 LOCAL SPEECH-TO-TEXT (faster-whisper)
# ========================================
TRANSCRIBER_URL=http://transcriber:8001
TRANSCRIBER_TIMEOUT=300
WHISPER_MODEL_SIZE=small
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ru
WHISPER_BEAM_SIZE=5

# ========================================
# 🔒 SECURITY (Дополнительно)
# ========================================
# Добавьте сюда дополнительные переменные:
# WEBHOOK_URL=https://yourdomain.com/webhook
# WEBHOOK_SECRET=your_webhook_secret
# ADMIN_USER_IDS=123456789,987654321
# ENCRYPTION_KEY=your_encryption_key
